programa
{
	real temp //abreviaçao de temperatura
	funcao inicio()
	{
		escreva("Informe a temperatura local\n")
		leia(temp)


		se(temp > 0){
		
			escreva("Esse valor eh positivo")
			
			} senao se (temp == 0){

				escreva("Esse valor eh neutro")							   	
	   	}  senao {

				escreva("Esse valor eh negativo")							   	
	   	}
	   
	}
 
}
