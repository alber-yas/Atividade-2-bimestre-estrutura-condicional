programa
{
	real n1, n2
	funcao inicio()
	{
		escreva("Informe o 1 numero\n")
		leia(n1)

		escreva("Informe o 2 numero\n")
		leia(n2)
		limpa()


		se(n1 > n2){
		
			escreva("O maior numero eh o numero ", n1)
			
			} senao {

				escreva("O maior numero eh o numero ", n2)						   	
	   	} 
	   
	}
 
}
